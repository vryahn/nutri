VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Opcional: monitoreo de errores en producción (Sentry). DSN publicable — se expone
# en el bundle cliente. Solo activo en build de producción; añadir también en Vercel.
# VITE_SENTRY_DSN=
# Opcional (F6): habilita "Datos con IA" en Alimentos (Gemini, key de AI Studio
# free tier sin billing; también hay que añadirla en Vercel → env vars).
# VITE_GEMINI_KEY=
# Opcional: habilita los chips de coincidencias USDA FoodData Central en "Datos con IA".
# Key gratuita en https://fdc.nal.usda.gov/api-key-signup — sin key, los chips no aparecen.
# VITE_FDC_KEY=
# Opcional: respaldo de "Datos con IA" si se agota/falla Gemini (cascada 3.5 → 2.5 → Mistral).
# Key en https://console.mistral.ai — sin key, la cascada termina en Gemini.
# VITE_MISTRAL_KEY=
# Opcional, SOLO dev local: auto-login de la cuenta de pruebas para verificación
# autónoma por IA (abrir http://localhost:5173/?dev=1). Nunca en Vercel.
# VITE_DEV_EMAIL=
# VITE_DEV_PASSWORD=
